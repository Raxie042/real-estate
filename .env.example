# Database
DATABASE_URL="postgresql://user:password@localhost:5432/realestate?schema=public"
POSTGRES_USER=realestate
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=realestate
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_URL="redis://localhost:6379"
REDIS_HOST=localhost
REDIS_PORT=6379

# Elasticsearch (optional)
ELASTICSEARCH_NODE="http://localhost:9200"
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=your_elastic_password

# Backend API
BACKEND_PORT=4000
NODE_ENV=development
API_PREFIX=api
API_VERSION=v1

# JWT Authentication
JWT_SECRET=your_jwt_secret_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_change_this
JWT_REFRESH_EXPIRES_IN=30d

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your_google_maps_key

# AWS S3 (for file uploads)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_S3_BUCKET=real-estate-images

# Email (SendGrid/SES)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your_sendgrid_api_key
EMAIL_FROM=noreply@yourrealestate.com

# MLS API Credentials (example for RESO)
MLS_RESO_CLIENT_ID=your_mls_client_id
MLS_RESO_CLIENT_SECRET=your_mls_client_secret
MLS_RESO_ENDPOINT=https://api.reso.org
MLS_RESO_AUTH_URL=https://auth.reso.org/oauth2/token

# Monitoring
SENTRY_DSN=your_sentry_dsn

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# CORS
CORS_ORIGIN=http://localhost:3000

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Feature Flags
ENABLE_ELASTICSEARCH=false
ENABLE_MLS_SYNC=false
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=false

# Currency API (for multi-currency support)
EXCHANGE_RATE_API_KEY=your_exchange_rate_api_key

# Geolocation
GEOLOCATION_API_KEY=your_geolocation_api_key

# Payment Gateway (Stripe)
STRIPE_PUBLIC_KEY=your_stripe_public_key
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
